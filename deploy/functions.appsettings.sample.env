# Azure Function App "Application settings" — Name__Sub form (double underscore).
# Set per app; many are shared. 🔒 = use a Key Vault reference, not a literal.
# See docs/05-Go-Live-Configuration.md for which app needs which.

# --- Cross-cutting: real endpoints (swap the mock URLs) ---
ExternalEndpoints__IvsBaseUrl=https://<ivs-host>/
ExternalEndpoints__ODataBaseUrl=https://<env>.operations.dynamics.com/data/
ExternalEndpoints__PricingCreditBaseUrl=https://<pricing-host>/
ExternalEndpoints__ShopifyBaseUrl=https://<catalog-host>/

# --- Outbound Entra auth to D365/IVS/pricing (prefer managed identity) ---
ExternalAuth__UseManagedIdentity=true
# ExternalAuth__TenantId=<guid>            # only if NOT using managed identity
# ExternalAuth__ClientId=<guid>            # only if NOT using managed identity
# ExternalAuth__ClientSecret=<🔒 KV ref>   # only if NOT using managed identity
ExternalAuth__Scopes__odata=https://<env>.operations.dynamics.com/.default
ExternalAuth__Scopes__ivs=<ivs-app-id-uri>/.default
ExternalAuth__Scopes__pricing-credit=<pricing-app-id-uri>/.default
# (leave a scope blank to send NO token for that client — used against the mocks)

# --- IVS / availability (Availability + ReservationRelease apps) ---
Ivs__EnvironmentId=usmf
Ivs__DefaultLocation=11
Ivs__ReservationTtlSeconds=900
Ivs__ReservationSweepCron=0 */2 * * * *
Availability__ClassBuffers__A=8
Availability__ClassBuffers__B=4
Availability__ClassBuffers__C=1
Availability__DefaultBuffer=4
Availability__LowStockThreshold=10

# --- Messaging (Writeback + Sync apps) — prefer identity-based ---
ServiceBusConnection__fullyQualifiedNamespace=<namespace>.servicebus.windows.net
# ServiceBusConnection=<🔒 KV ref>          # alternative: SAS connection string
OrderIntake__QueueName=orders-inbound
StatusOutbound__TopicName=status-outbound

# --- Durable stores (shared Redis across Availability/Writeback/Sync/ReservationRelease) ---
Redis__ConnectionString=<🔒 KV: redis-connection-string>

# --- Writeback price integrity (TDD §9); omit the section to disable ---
PriceIntegrity__ToleranceFraction=0.05

# --- Platform ---
KeyVault__Uri=https://kv-portal-prod.vault.azure.net/
AzureWebJobsStorage=<🔒 KV: storage-connection-string, or identity>
APPLICATIONINSIGHTS_CONNECTION_STRING=<from App Insights>
FUNCTIONS_WORKER_RUNTIME=dotnet-isolated
