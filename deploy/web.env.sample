# SPA (storefront/web) environment.
#
# Production: the SPA calls the BFF via the RELATIVE path /api (same-origin) — no build-time API URL.
# Route /api/* to the BFF using the Static Web App "Linked Backend" (or Front Door). There is no
# production API base env var by design.
#
# Dev only — Vite proxy target for /api (defaults to http://localhost:5080):
VITE_BFF_URL=http://localhost:5080

# Future (when the Stripe Payment Element lands in the SPA — see docs/05 §G1):
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx   # publishable key is safe in the client (not a secret)
