{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",
    "ServiceBusConnection": "<local-emulator-or-set-via-keyvault>",
    "ExternalEndpoints__IvsBaseUrl": "http://localhost:5101",
    "ExternalEndpoints__ODataBaseUrl": "http://localhost:5102",
    "ExternalEndpoints__PricingCreditBaseUrl": "http://localhost:5103",
    "Ivs__EnvironmentId": "usmf",
    "Ivs__DefaultLocation": "11",
    "Ivs__ReservationTtlSeconds": "900",
    "Availability__DefaultBuffer": "0",
    "Availability__LowStockThreshold": "5"
  }
}
